generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

model Contact {
  id            String                 @id @default(cuid())
  name          String
  emails        String[]
  phones        String[]
  role          String?
  artistContext String?
  source        ContactSource          @default(MANUAL)
  externalId    String?
  lastSyncedAt  DateTime?
  raw           Json?
  embedding     Unsupported("vector")?
  notes         String?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  calls         Call[]
  followUps     FollowUp[]
  mailThreads   MailThread[]

  @@index([externalId, source])
  @@index([updatedAt])
}

model Call {
  id              String                 @id @default(cuid())
  contactId       String
  direction       Direction
  startedAt       DateTime
  durationSeconds Int?
  reason          String?
  conclusion      String?
  sentiment       String?
  rawTranscript   String?
  embedding       Unsupported("vector")?
  enrichedAt      DateTime?
  createdAt       DateTime               @default(now())
  contact         Contact                @relation(fields: [contactId], references: [id], onDelete: Cascade)
  followUp        FollowUp?

  @@index([contactId, startedAt])
}

model FollowUp {
  id          String    @id @default(cuid())
  contactId   String
  callId      String?   @unique
  scheduledAt DateTime
  completed   Boolean   @default(false)
  completedAt DateTime?
  notes       String?
  createdAt   DateTime  @default(now())
  call        Call?     @relation(fields: [callId], references: [id])
  contact     Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([scheduledAt, completed])
}

model MailThread {
  id            String   @id @default(cuid())
  contactId     String?
  gmailThreadId String   @unique
  subject       String
  snippet       String?
  lastMessageAt DateTime
  messageCount  Int      @default(1)
  labelIds      String[]
  needsReply    Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  contact       Contact? @relation(fields: [contactId], references: [id])

  @@index([contactId, lastMessageAt])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          String    @default("user")
  createdAt     DateTime  @default(now())
  accounts      Account[]
  sessions      Session[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model AppSettings {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt

  @@map("app_settings")
}

enum ContactSource {
  MANUAL
  GOOGLE
  ICLOUD
  OUTLOOK
}

enum Direction {
  INBOUND
  OUTBOUND
}
